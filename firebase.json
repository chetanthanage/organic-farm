{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "SETUP_GUIDE.md",
      "CHANGES.md",
      "FIRESTORE_SCHEMA.md",
      "MIGRATION_NOTES.md",
      "download_images.sh"
    ],
    "headers": [
      {
        "source": "/admin/**",
        "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }]
      }
    ],
    "cleanUrls": true,
    "trailingSlash": false
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  }
}
